.DS_Store
tmux/custom/*.local

# --- ZSH ignores ---
shells/zsh/load.zsh
shells/zsh/custom/
!shells/zsh/custom/.gitkeep
!shells/zsh/custom/custom_example

# --- System ignores ---
.idea
tools/tui/ghostty/fonts
tools/tui/kitty/platform.conf
tools/scripts/current_wallpaper.jpg
tools/tui/ghostty/fonts
tools/multiplex/tmux/plugins
shells/fish/fish_variables

# --- (n)vim ignores ---
nvim/.netrwhist
nvim/plugged
nvim/lazy-lock.json
.netrwhist

# --- Git configs (personal — use .example files) ---
tools/git/gitconfig_marzun
tools/git/gitconfig_crb
tools/git/gitconfig_crb_linux
tools/git/gitconfig_tl_linux

# --- Hypr ignores ---
tools/wayland/hypr/monitors.conf

# --- Sway / Kanshi ignores ---
tools/wayland/sway/monitors.conf
tools/wayland/kanshi/config

# --- Cosmic Ignores ---

# Ignore current session/runtime states
tools/wayland/cosmic/com.system76.CosmicTheme.Mode/
tools/wayland/cosmic/com.system76.CosmicSettings.WindowRules/
tools/wayland/cosmic/com.system76.CosmicAppletWorkspaces/
tools/wayland/cosmic/xdg-desktop-portal-cosmic/
tools/wayland/cosmic/com.system76.CosmicPortal/v1/screenshot

# Ignore dynamic notification state but KEEP the folder for 'anchor'
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/do_not_disturb
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/max_notifications
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/max_per_app
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/max_timeout_low
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/max_timeout_normal
tools/wayland/cosmic/com.system76.CosmicNotifications/v1/max_timeout_urgent

# Ignore File Manager session data
tools/wayland/cosmic/com.system76.CosmicFiles/*/tab.conf

# Ignore generic locks and temps
tools/wayland/cosmic/*.lock
tools/wayland/cosmic/*.tmp
tools/wayland/cosmic/com.system76.CosmicIdle/v1
tools/wayland/cosmic/com.system76.CosmicBackground/v1
tools/wayland/cosmic/com.system76.CosmicSettings.Wallpaper/v1
tools/wayland/cosmic/com.system76.CosmicFiles/v1
/tools/arch/arch_migration_audit.txt
tools/nvim/nvim-pack-lock.json
